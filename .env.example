# ─────────────────────────────────────────────
# Supabase (Project Settings → API)
# ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only, never exposed to the browser. Used by the admin dashboard + enquiry route.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────
# Email notifications (Resend – free tier: 3,000 emails/mo)
# https://resend.com
# ─────────────────────────────────────────────
RESEND_API_KEY=your-resend-api-key
ADMIN_NOTIFICATION_EMAIL=reservations@heritageheavenhotels.com
EMAIL_FROM="Heritage Heaven Hotels <enquiries@heritageheavenhotels.com>"

# ─────────────────────────────────────────────
# WhatsApp business number enquiries are sent to (E.164, no + or spaces)
# ─────────────────────────────────────────────
NEXT_PUBLIC_WHATSAPP_NUMBER=919876543210

# ─────────────────────────────────────────────
# Site
# ─────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://heritageheavenhotels.com

# ─────────────────────────────────────────────
# Analytics
# ─────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-search-console-verification-code
